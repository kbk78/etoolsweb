<!DOCTYPE html>
<html lang="en">

<head>
  <title>etoolsweb</title>
	<link type="text/css" rel="stylesheet" href="https://unpkg.com/bootstrap/dist/css/bootstrap.min.css"/>
	<link type="text/css" rel="stylesheet" href="https://unpkg.com/bootstrap-vue@latest/dist/bootstrap-vue.min.css"/>

	<script src="https://unpkg.com/vue/dist/vue.min.js"></script>
	<script src="https://cdn.jsdelivr.net/npm/vue-clipboards@1.2.4/dist/vue-clipboards.min.js"></script>
	<script src="https://unpkg.com/bootstrap-vue@latest/dist/bootstrap-vue.min.js"></script>

	<script src="https://unpkg.com/crossfilter2@1.4.7/crossfilter.min.js"></script>
	<script src="https://d3js.org/d3.v5.min.js"></script>
	<script src="http://unpkg.com/dc@3/dc.js"></script>

	<script src="simdata.js"></script>

</head>
<body>
	
<div id = "app-6">
	<br><br>
	<b-container fluid style="border:1px solid #cecece;">
		<label for="simfile">Select weather file</label><br>
		<b-form-file id='simfile' placeholder="Choose *.csv simdata file" @input="openFile"></b-form-file><br><br>
		<b-form-input v-model='bins' type="range" min=1 max=100 id="myrange" @change="plotch"></b-form-input><br><br>
		<input v-model.lazy="bins" placeholder="edit me" @change="plotch"><br>
		<p>Bin width: {{ bins }}</p> <br>
		<div id = 'ch1'></div>

	        <b-button variant = "outline-primary" v-clipboard:copy="objtoarray(items)">Copy</b-button>
		<b-table  striped hover :items="items" fields="temps"></b-table>

	</b-container>

</div>
<br>
<br>

<div id = "apptest">
	        <button  v-clipboard:copy="message">Copy</button>
</div>

</body>
</html>
